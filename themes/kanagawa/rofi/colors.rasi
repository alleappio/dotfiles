* {
    background: #181616;
    foreground: #c5c9c5;
    background-alt: #0d0c0c;
    black: #0d0c0c;
    red: #c4746e;
    green: #8a9a7b;
    yellow: #c4b28a;
    blue: #8ba4b0;
    magenta: #a292a3;
    cyan: #8ea4a2;
    white: #c8c093;
    primary:        var(blue);
    selected:       var(blue);
    urgent:         var(magenta);
}

