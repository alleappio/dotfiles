* {
    background: #161617;
    background-alt: #27272a;
    foreground: #c9c7cd;
    black: #27272a;
    red: #ea83a5;
    green: #90b99f;
    yellow: #e6b99d;
    blue: #9ca2cf;
    purple: #e29eca;
    cyan: #85b5ba;
    white: #c9c7cd;
    primary: var(blue);
    selected: var(blue);
    urgent: var(red);
}

