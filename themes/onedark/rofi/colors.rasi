* {
    background:     #282c34;
    background-alt: #31353f;
    foreground:     #ABB2BF;
    red:            #e06c75;
    blue:           #61afef;
    green:          #98c379;
    purple:         #c678dd;
    yellow:         #d19a66; 
    primary:        var(green);
    selected:       var(blue);
    urgent:         var(purple);
}
